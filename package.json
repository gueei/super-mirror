{
  "name": "super-mirror",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:code && npm run build:ui",
    "build:code": "esbuild src/code.ts --bundle --platform=browser --format=iife --target=es2020 --outfile=dist/code.js",
    "build:ui": "esbuild src/ui.ts --bundle --platform=browser --format=iife --target=es2020 --outfile=dist/ui.js",
    "watch": "esbuild src/code.ts --bundle --platform=browser --format=iife --target=es2020 --outfile=dist/code.js --watch",
    "test": "tsx --test tests/*.test.ts"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.117.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.11",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
